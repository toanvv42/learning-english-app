{
  "name": "learning-english-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "pages:build": "opennextjs-cloudflare build",
    "pages:deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "pages:deploy:built": "opennextjs-cloudflare deploy",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "secrets:scan": "gitleaks detect --source . --redact --no-banner --exit-code 1",
    "dev:pronunciation": "cd services/pronunciation-api && uvicorn app.main:app --reload --port 8000",
    "test:pronunciation": "cd services/pronunciation-api && pytest",
    "docker:pronunciation": "docker compose -f services/pronunciation-api/docker-compose.yml up --build"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.699.0",
    "@aws-sdk/s3-request-presigner": "^3.699.0",
    "@google/genai": "1.51.0",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.46.1",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "1.14.0",
    "next": "^15.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "3.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "1.19.5",
    "@types/node": "^22.10.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.15.0",
    "eslint-config-next": "^15.0.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.7.2",
    "wrangler": "4.87.0"
  }
}
